# Intent Engineering — ephemeral lens run scratch (published reports: docs/intent-engineering/)
.intense/runs/

# Optional personal scratch (not the plugin default). Legacy .wip/ — do not reintroduce as default.
wip/
.wip/

# Some environments globally ignore `agents/` (several AI coding tools add this to a
# global gitignore). This plugin SHIPS its lens agents in plugins/intent-engineering/agents/,
# so re-include them — otherwise a clone on such a machine has zero agents and the plugin
# is broken. Defensive; keep this negation on any clone/fork.
!plugins/intent-engineering/agents/
!plugins/intent-engineering/agents/**

# OS / editor
.DS_Store
# IDE — also covered by a common global gitignore, but list it here so the repo is
# self-protecting for contributors without that global config (same lesson as agents/).
.idea/
